<!-- MODAL -->
<div id="modalOverlay" class="modal-overlay hidden" onclick="closeModal(event)">
  <div class="modal-box">
    <button class="modal-close" onclick="document.getElementById('modalOverlay').classList.add('hidden')">✕</button>
    <div id="modalContent"></div>
  </div>
</div>

<script>
  // QUOTES
  const quotes = [
    { text: "Mindfulness means paying attention in a particular way: on purpose, in the present moment, and non-judgmentally.", author: "Jon Kabat-Zinn, PhD — founder of Mindfulness-Based Stress Reduction (MBSR)" },
    { text: "The greatest weapon against stress is our ability to choose one thought over another.", author: "William James, MD — pioneering psychologist and physician" },
    { text: "Gratitude is not only the greatest of virtues, but the parent of all others.", author: "Martin Seligman, PhD — founder of Positive Psychology" },
  ];
  let qIdx = 0;
  function setQuote(i) {
    qIdx = i;
    const qt = document.getElementById('quoteText'), qa = document.getElementById('quoteAuthor');
    qt.style.opacity = 0; qt.style.transform = 'translateY(8px)';
    setTimeout(() => {
      qt.textContent = '"' + quotes[i].text + '"';
      qa.textContent = '— ' + quotes[i].author;
      qt.style.transition = 'opacity 0.5s, transform 0.5s';
      qt.style.opacity = 1; qt.style.transform = 'translateY(0)';
    }, 300);
    document.querySelectorAll('.qdot').forEach((d, j) => d.classList.toggle('active', i === j));
  }
  setInterval(() => setQuote((qIdx + 1) % quotes.length), 5500);

  // BREATHWORK
  let breathActive = false, breathInterval = null, countInterval = null, phaseIdx = 0;
  const phases = [{ label: 'Inhale', duration: 4 }, { label: 'Hold', duration: 4 }, { label: 'Exhale', duration: 6 }];
  function toggleBreath() {
    breathActive = !breathActive;
    const btn = document.getElementById('breathBtn');
    if (breathActive) {
      btn.textContent = 'Pause'; btn.classList.add('pause'); phaseIdx = 0; runPhase();
    } else {
      btn.textContent = 'Begin Breathing'; btn.classList.remove('pause');
      clearTimeout(breathInterval); clearInterval(countInterval);
      resetRings();
      document.getElementById('breathPhaseLabel').textContent = 'ready';
      document.getElementById('breathCountLabel').textContent = '';
    }
  }
  function runPhase() {
    if (!breathActive) return;
    const p = phases[phaseIdx % phases.length];
    document.getElementById('breathPhaseLabel').textContent = p.label;
    let count = p.duration;
    document.getElementById('breathCountLabel').textContent = count;
    clearInterval(countInterval);
    countInterval = setInterval(() => { count--; document.getElementById('breathCountLabel').textContent = Math.max(0, count); }, 1000);
    animateRings(p.label);
    breathInterval = setTimeout(() => { phaseIdx++; runPhase(); }, p.duration * 1000);
  }
  function animateRings(phase) {
    const r1 = document.getElementById('ring1'), r2 = document.getElementById('ring2'), r3 = document.getElementById('ring3');
    if (phase === 'Inhale') { r1.style.width = r1.style.height = '120px'; r2.style.width = r2.style.height = '200px'; r3.style.width = r3.style.height = '270px'; }
    else if (phase === 'Exhale') { r1.style.width = r1.style.height = '70px'; r2.style.width = r2.style.height = '150px'; r3.style.width = r3.style.height = '230px'; }
  }
  function resetRings() {
    const sizes = ['90px','170px','250px'];
    ['ring1','ring2','ring3'].forEach((id, i) => { document.getElementById(id).style.width = document.getElementById(id).style.height = sizes[i]; });
  }

  // MOOD
  const moodMessages = [
    "We see you. It takes real courage to acknowledge this. Try the Body Scan Release — just 8 minutes, and it asks nothing of you except to lie down. You deserve gentleness right now. 🌿",
    "Low days are a part of being fully human. A 5-minute breath reset can gently shift the energy without demanding anything. You don't have to feel better — just a little softer is enough. 🌅",
    "Okay is more than enough. You showed up, and that matters. A short evening yoga flow or a quiet journal entry might warm the day a little. You're doing well by simply being here. 🌿",
    "Good energy deserves to be honoured and remembered. Try the Gratitude Journal today — capture what's working so you can return to it on harder days. These moments matter. 📓",
    "You are genuinely glowing today. Let this feeling ripple outward — write it down, call someone you love, or share it in our community. Thriving is worth celebrating openly. 🌟",
  ];
  function selectMood(i) {
    document.querySelectorAll('.mood-item').forEach((el, j) => { el.classList.toggle('selected', i===j); el.classList.toggle('dimmed', i!==j); });
    document.getElementById('moodMsg').textContent = moodMessages[i];
    document.getElementById('moodResponse').classList.remove('hidden');
  }

  // FAQ
  function toggleFaq(el) {
    const item = el.parentElement;
    const wasOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
    if (!wasOpen) item.classList.add('open');
  }

  // NEWSLETTER
  function subscribeNewsletter() {
    const email = document.getElementById('emailInput').value;
    const msg = document.getElementById('newsletterMsg');
    if (!email || !email.includes('@')) { msg.textContent = 'Please enter a valid email address.'; msg.style.color = '#D4736A'; return; }
    msg.textContent = '🌿 Welcome to the community! Your first letter arrives this Sunday morning.';
    msg.style.color = 'var(--sage)';
    document.getElementById('emailInput').value = '';
  }

  // MODALS
  const modalData = {
    mind: {
      icon: '🧘', tag: 'Mind Pillar', title: 'Mental Wellbeing',
      body: 'Your mental health is the foundation of everything else. Our tools draw on Mindfulness-Based Stress Reduction (MBSR), cognitive behavioural principles, and sleep science — all areas with robust peer-reviewed evidence supporting their effectiveness for stress, anxiety, and mental fatigue.',
      points: ['Guided meditations based on MBSR protocols (3–30 minutes)', 'Breathwork exercises with parasympathetic nervous system basis', 'Sleep hygiene guides grounded in sleep science research', 'Cognitive reframing exercises informed by CBT principles', 'Daily micro-practices for emotional regulation', 'Stress reduction techniques drawn from published MBSR literature']
    },
    body: {
      icon: '🌿', tag: 'Body Pillar', title: 'Physical Wellbeing',
      body: 'Physical activity and mindful movement have strong evidence bases for improving both physical and mental health. Our practices are informed by exercise physiology research and designed to be inclusive — accessible at any fitness level, age, or ability.',
      points: ['Beginner-friendly yoga informed by restorative practice research', 'Bodyweight strength routines based on exercise physiology principles', 'Morning movement sequences (5–15 minutes) to reduce sedentary behaviour', 'Tension release practices for desk workers, supported by occupational health research', 'Walking meditations combining physical activity and mindfulness', 'Post-exercise recovery routines aligned with sports science recommendations']
    },
    soul: {
      icon: '☀️', tag: 'Soul Pillar', title: 'Emotional & Inner Wellbeing',
      body: 'Positive psychology research consistently identifies meaning, connection, and self-reflection as core contributors to life satisfaction and resilience. Our practices in this pillar draw on the work of researchers including Dr Martin Seligman and Dr Kristin Neff.',
      points: ['Daily guided journaling with prompts drawn from positive psychology', 'Gratitude practices supported by Seligman & Csikszentmihalyi research', 'Values clarification exercises rooted in Acceptance & Commitment Therapy (ACT)', 'Self-compassion practices informed by Dr Kristin Neff\'s research', 'Seasonal reflection and intention-setting rituals', 'Practices for navigating grief and life transitions']
    },
    nourish: {
      icon: '🍃', tag: 'Nourish Pillar', title: 'Nutritional Wellbeing',
      body: 'Our nutritional guidance is aligned with evidence-based dietary frameworks including the Harvard Healthy Eating Plate and current WHO dietary guidelines. We focus on sustainable, whole-food patterns rather than restrictive or fad-based approaches.',
      points: ['Plant-forward recipes aligned with WHO dietary recommendations', 'Hydration guidance based on established physiological research', 'Mindful eating practices supported by behavioural nutrition research', 'Anti-inflammatory food guidance based on peer-reviewed nutritional science', 'Practical meal preparation tips to support dietary adherence', 'Guidance on building a sustainable, non-restrictive relationship with food']
    }
  };
  function openModal(key) {
    const d = modalData[key];
    document.getElementById('modalContent').innerHTML =
      '<div style="font-size:2.5rem;margin-bottom:16px">' + d.icon + '</div>' +
      '<span class="modal-tag">' + d.tag + '</span>' +
      '<h3>' + d.title + '</h3>' +
      '<p>' + d.body + '</p>' +
      '<ul>' + d.points.map(p => '<li>' + p + '</li>').join('') + '</ul>' +
      '<button class="btn-primary" onclick="document.getElementById(\'modalOverlay\').classList.add(\'hidden\');document.getElementById(\'nutrition\').scrollIntoView({behavior:\'smooth\'})">Explore Practices →</button>';
    document.getElementById('modalOverlay').classList.remove('hidden');
  }
  function closeModal(e) {
    if (e.target.id === 'modalOverlay') document.getElementById('modalOverlay').classList.add('hidden');
  }
</script>
