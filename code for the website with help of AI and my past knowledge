<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Bloomwell — Nourish Your Mind, Body & Spirit</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --sage: #7EB5A6; --sage-light: #A8C5A0; --earth: #D4B896;
      --cream: #F7F3EE; --deep: #2C3E35; --mid: #5a6b62; --white: #ffffff;
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Jost', sans-serif; background: var(--cream); color: var(--deep); overflow-x: hidden; }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--cream); }
    ::-webkit-scrollbar-thumb { background: var(--sage-light); border-radius: 3px; }

    /* NAV */
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(247,243,238,0.93); backdrop-filter: blur(14px); border-bottom: 1px solid rgba(126,181,166,0.2); display: flex; align-items: center; justify-content: space-between; padding: 0 6%; height: 64px; }
    .logo { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 300; letter-spacing: 0.04em; color: var(--deep); }
    .logo span { color: var(--sage); font-style: italic; }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a { text-decoration: none; color: var(--mid); font-size: 0.75rem; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 300; transition: color 0.3s; padding-bottom: 2px; border-bottom: 1px solid transparent; }
    .nav-links a:hover { color: var(--sage); border-bottom-color: var(--sage); }
    .nav-cta { background: var(--sage); color: #fff; padding: 8px 22px; border-radius: 30px; font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 400; border: none; cursor: pointer; transition: background 0.3s, transform 0.2s; }
    .nav-cta:hover { background: #6aa394; transform: translateY(-1px); }

    /* HERO */
    #home { min-height: 100vh; display: flex; align-items: center; padding: 80px 6% 60px; background: linear-gradient(135deg, #F7F3EE 0%, #EDF4F1 55%, #F0EDE8 100%); position: relative; overflow: hidden; }
    .hero-orb { position: absolute; border-radius: 50%; pointer-events: none; }
    .orb1 { top: 8%; right: 4%; width: 420px; height: 420px; background: radial-gradient(circle, rgba(126,181,166,0.13) 0%, transparent 70%); }
    .orb2 { bottom: 4%; right: 22%; width: 240px; height: 240px; background: radial-gradient(circle, rgba(168,197,160,0.18) 0%, transparent 70%); }
    .orb3 { top: 35%; right: 12%; width: 520px; height: 520px; border: 1px solid rgba(126,181,166,0.13); background: transparent; }
    .hero-content { max-width: 680px; }
    .eyebrow { font-size: 0.72rem; letter-spacing: 0.24em; text-transform: uppercase; color: var(--sage); margin-bottom: 20px; font-weight: 300; animation: riseIn 1s 0.1s both; }
    h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(3rem, 6vw, 5.5rem); font-weight: 300; line-height: 1.08; color: var(--deep); margin-bottom: 28px; animation: riseIn 1s 0.25s both; }
    h1 em { color: var(--sage); font-style: italic; }
    .hero-sub { font-size: 0.95rem; line-height: 1.85; color: var(--mid); max-width: 460px; margin-bottom: 40px; font-weight: 300; animation: riseIn 1s 0.45s both; }
    .btn-group { display: flex; gap: 14px; flex-wrap: wrap; animation: riseIn 1s 0.6s both; }
    .btn-primary { background: var(--deep); color: var(--cream); padding: 14px 36px; border-radius: 40px; font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; border: none; cursor: pointer; transition: background 0.3s, transform 0.2s; font-family: 'Jost', sans-serif; }
    .btn-primary:hover { background: #3d5548; transform: translateY(-2px); }
    .btn-ghost { background: transparent; color: var(--deep); padding: 14px 36px; border-radius: 40px; font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; border: 1px solid rgba(44,62,53,0.28); cursor: pointer; transition: border-color 0.3s, transform 0.2s; font-family: 'Jost', sans-serif; }
    .btn-ghost:hover { border-color: var(--sage); color: var(--sage); transform: translateY(-2px); }
    .floating-card { position: absolute; right: 7%; top: 50%; transform: translateY(-50%); width: 300px; height: 300px; border-radius: 50%; background: linear-gradient(135deg, rgba(126,181,166,0.25), rgba(168,197,160,0.15)); border: 1px solid rgba(126,181,166,0.3); box-shadow: 0 0 90px rgba(126,181,166,0.18); display: flex; align-items: center; justify-content: center; flex-direction: column; animation: floatUp 6s ease-in-out infinite; }
    .floating-card .icon { font-size: 5rem; }
    .floating-card p { font-family: 'Cormorant Garamond', serif; font-style: italic; color: var(--mid); font-size: 1rem; margin-top: 10px; }

    /* STATS */
    .stats-bar { background: var(--white); padding: 40px 6%; display: flex; justify-content: space-around; flex-wrap: wrap; gap: 24px; border-bottom: 1px solid rgba(126,181,166,0.12); }
    .stat { text-align: center; }
    .stat-num { font-family: 'Cormorant Garamond', serif; font-size: 2.6rem; font-weight: 300; color: var(--sage); line-height: 1; }
    .stat-label { font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mid); font-weight: 300; margin-top: 6px; }

    /* QUOTE */
    .quote-section { background: var(--deep); padding: 56px 8%; text-align: center; }
    .quote-text { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.3rem, 2.5vw, 1.9rem); font-weight: 300; font-style: italic; line-height: 1.65; color: var(--cream); max-width: 720px; margin: 0 auto 14px; transition: opacity 0.5s, transform 0.5s; }
    .quote-author { font-size: 0.75rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--sage); font-weight: 300; }
    .quote-dots { display: flex; gap: 8px; justify-content: center; margin-top: 22px; }
    .qdot { height: 8px; border-radius: 4px; background: rgba(247,243,238,0.25); cursor: pointer; transition: all 0.4s; width: 8px; }
    .qdot.active { background: var(--sage); width: 24px; }

    /* PILLARS */
    #mindfulness { padding: 100px 6%; background: var(--cream); }
    .section-header { text-align: center; margin-bottom: 64px; }
    .section-header .eyebrow { animation: none; }
    .section-header h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 300; color: var(--deep); }
    .section-header h2 em { color: var(--sage); }
    .section-header p { font-size: 0.9rem; color: var(--mid); font-weight: 300; line-height: 1.8; max-width: 560px; margin: 16px auto 0; }
    .pillars-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 24px; }
    .pillar-card { background: var(--white); border-radius: 20px; padding: 36px; border: 1px solid rgba(126,181,166,0.15); box-shadow: 0 4px 20px rgba(44,62,53,0.06); transition: transform 0.4s cubic-bezier(.23,1.02,.64,1), box-shadow 0.4s; cursor: pointer; }
    .pillar-card:hover { transform: translateY(-10px); box-shadow: 0 28px 52px rgba(44,62,53,0.13); }
    .pillar-icon { width: 64px; height: 64px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin-bottom: 20px; }
    .pillar-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.65rem; font-weight: 400; color: var(--deep); margin-bottom: 12px; }
    .pillar-card p { font-size: 0.87rem; line-height: 1.8; color: var(--mid); font-weight: 300; margin-bottom: 18px; }
    .tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .tag { padding: 4px 12px; border-radius: 20px; font-size: 0.68rem; letter-spacing: 0.08em; font-weight: 400; }

    /* BREATHWORK */
    #movement { padding: 100px 6%; background: linear-gradient(135deg, #EDF4F1, #F0EDE8); }
    .breath-layout { display: flex; align-items: center; gap: 8%; flex-wrap: wrap; }
    .breath-copy { flex: 1 1 300px; }
    .breath-copy h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 300; color: var(--deep); margin-bottom: 20px; }
    .breath-copy h2 em { color: var(--sage); }
    .breath-copy p { font-size: 0.9rem; line-height: 1.85; color: var(--mid); font-weight: 300; margin-bottom: 16px; }
    .breath-tips { list-style: none; margin-bottom: 32px; }
    .breath-tips li { font-size: 0.85rem; color: var(--mid); font-weight: 300; padding: 6px 0 6px 20px; position: relative; line-height: 1.6; }
    .breath-tips li::before { content: '✦'; position: absolute; left: 0; color: var(--sage); font-size: 0.55rem; top: 10px; }
    .breath-btn { background: var(--sage); color: #fff; padding: 14px 36px; border-radius: 40px; font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; border: none; cursor: pointer; font-family: 'Jost', sans-serif; transition: background 0.3s, transform 0.2s; }
    .breath-btn:hover { background: #6aa394; transform: translateY(-2px); }
    .breath-btn.pause { background: var(--mid); }
    .breath-visual { flex: 0 0 300px; display: flex; align-items: center; justify-content: center; }
    .breath-rings { position: relative; width: 280px; height: 280px; display: flex; align-items: center; justify-content: center; }
    .ring { position: absolute; border-radius: 50%; border: 1px solid rgba(126,181,166,0.45); transition: width 4s cubic-bezier(0.4,0,0.2,1), height 4s cubic-bezier(0.4,0,0.2,1); }
    .ring1 { width: 90px; height: 90px; background: rgba(126,181,166,0.12); }
    .ring2 { width: 170px; height: 170px; border-color: rgba(126,181,166,0.28); }
    .ring3 { width: 250px; height: 250px; border-color: rgba(126,181,166,0.12); }
    .breath-label { position: absolute; text-align: center; z-index: 2; }
    .breath-label p { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-style: italic; color: var(--deep); }
    .breath-label span { font-size: 2.2rem; color: var(--sage); font-weight: 300; display: block; }

    /* PRACTICES */
    #nutrition { padding: 100px 6%; background: var(--white); }
    .practices-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; }
    .practice-card { background: var(--cream); border-radius: 16px; padding: 28px; border: 1px solid rgba(126,181,166,0.12); transition: transform 0.3s, box-shadow 0.3s; cursor: pointer; }
    .practice-card:hover { transform: translateY(-5px); box-shadow: 0 14px 36px rgba(44,62,53,0.1); }
    .practice-header { display: flex; align-items: flex-start; gap: 14px; margin-bottom: 14px; }
    .practice-icon { font-size: 2.2rem; flex-shrink: 0; }
    .practice-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 6px; }
    .practice-title { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 400; color: var(--deep); }
    .practice-time { font-size: 0.7rem; color: var(--sage); letter-spacing: 0.06em; flex-shrink: 0; margin-left: 8px; }
    .practice-desc { font-size: 0.84rem; line-height: 1.75; color: var(--mid); font-weight: 300; margin-bottom: 14px; }
    .practice-steps { font-size: 0.78rem; color: var(--mid); font-weight: 300; line-height: 1.7; padding-left: 14px; border-left: 2px solid rgba(126,181,166,0.3); }
    .practice-steps p { margin-bottom: 3px; }

    /* TESTIMONIALS */
    .testimonials-section { padding: 100px 6%; background: var(--cream); }
    .testimonials-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
    .testimonial-card { background: var(--white); border-radius: 20px; padding: 36px; border: 1px solid rgba(126,181,166,0.12); box-shadow: 0 4px 20px rgba(44,62,53,0.05); }
    .stars { color: var(--sage); font-size: 1rem; margin-bottom: 16px; letter-spacing: 2px; }
    .testimonial-text { font-family: 'Cormorant Garamond', serif; font-size: 1.05rem; font-style: italic; font-weight: 300; line-height: 1.75; color: var(--deep); margin-bottom: 20px; }
    .testimonial-author { display: flex; align-items: center; gap: 12px; }
    .author-avatar { width: 42px; height: 42px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; flex-shrink: 0; }
    .author-name { font-size: 0.82rem; font-weight: 500; color: var(--deep); }
    .author-role { font-size: 0.72rem; color: var(--mid); font-weight: 300; }

    /* NEWSLETTER */
    .newsletter-section { padding: 80px 6%; background: var(--deep); text-align: center; }
    .newsletter-section h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.8rem, 3.5vw, 2.8rem); font-weight: 300; color: var(--cream); margin-bottom: 12px; }
    .newsletter-section h2 em { color: var(--sage); }
    .newsletter-section > p { font-size: 0.88rem; color: rgba(247,243,238,0.55); margin-bottom: 36px; font-weight: 300; }
    .newsletter-form { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; max-width: 520px; margin: 0 auto; }
    .newsletter-form input { flex: 1 1 220px; padding: 14px 20px; border-radius: 40px; border: 1px solid rgba(126,181,166,0.3); background: rgba(247,243,238,0.08); color: var(--cream); font-family: 'Jost', sans-serif; font-size: 0.88rem; font-weight: 300; outline: none; }
    .newsletter-form input::placeholder { color: rgba(247,243,238,0.4); }
    .newsletter-form input:focus { border-color: var(--sage); }
    .newsletter-form button { background: var(--sage); color: #fff; padding: 14px 28px; border-radius: 40px; font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; border: none; cursor: pointer; font-family: 'Jost', sans-serif; transition: background 0.3s, transform 0.2s; }
    .newsletter-form button:hover { background: #6aa394; transform: translateY(-2px); }
    .newsletter-note { font-size: 0.7rem; color: rgba(247,243,238,0.35); margin-top: 14px; }

    /* MOOD */
    #community { padding: 80px 6%; background: var(--deep); text-align: center; }
    #community .eyebrow { color: var(--sage); }
    #community h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.8rem, 3.5vw, 2.8rem); font-weight: 300; color: var(--cream); margin-bottom: 12px; }
    #community h2 em { color: var(--sage); }
    #community > p { font-size: 0.88rem; color: rgba(247,243,238,0.55); margin-bottom: 42px; font-weight: 300; }
    .moods { display: flex; gap: 24px; justify-content: center; flex-wrap: wrap; margin-bottom: 28px; }
    .mood-item { text-align: center; cursor: pointer; }
    .mood-emoji { font-size: 2.6rem; display: block; transition: transform 0.3s, filter 0.3s; filter: grayscale(20%); }
    .mood-item:hover .mood-emoji, .mood-item.selected .mood-emoji { transform: scale(1.35); filter: none; }
    .mood-item.dimmed .mood-emoji { filter: grayscale(80%); opacity: 0.4; }
    .mood-label { font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.12em; color: rgba(247,243,238,0.45); margin-top: 6px; display: block; }
    .mood-response { background: rgba(126,181,166,0.15); border-radius: 12px; padding: 18px 32px; display: inline-block; border-left: 3px solid var(--sage); animation: fadeUp 0.4s ease; max-width: 600px; }
    .mood-response p { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.1rem; color: var(--cream); line-height: 1.7; }
    .hidden { display: none !important; }

    /* FAQ */
    .faq-section { padding: 100px 6%; background: var(--white); }
    .faq-list { max-width: 740px; margin: 0 auto; }
    .faq-item { border-bottom: 1px solid rgba(126,181,166,0.2); }
    .faq-question { padding: 22px 0; cursor: pointer; display: flex; justify-content: space-between; align-items: center; font-family: 'Cormorant Garamond', serif; font-size: 1.15rem; font-weight: 400; color: var(--deep); }
    .faq-question:hover { color: var(--sage); }
    .faq-arrow { font-size: 1.1rem; transition: transform 0.3s; color: var(--sage); }
    .faq-answer { font-size: 0.88rem; line-height: 1.85; color: var(--mid); font-weight: 300; max-height: 0; overflow: hidden; transition: max-height 0.4s ease, padding 0.3s; }
    .faq-item.open .faq-answer { max-height: 300px; padding-bottom: 20px; }
    .faq-item.open .faq-arrow { transform: rotate(180deg); }

    /* FOOTER */
    footer { background: #1e2e27; padding: 60px 6% 40px; }
    .footer-top { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; margin-bottom: 48px; }
    .footer-logo { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 300; color: var(--cream); margin-bottom: 14px; }
    .footer-logo span { color: var(--sage); font-style: italic; }
    .footer-about { font-size: 0.82rem; line-height: 1.8; color: rgba(247,243,238,0.45); font-weight: 300; max-width: 260px; margin-bottom: 16px; }
    .footer-disclaimer { font-size: 0.7rem; color: rgba(247,243,238,0.22); font-weight: 300; }
    .footer-col h4 { font-size: 0.72rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--sage); font-weight: 400; margin-bottom: 18px; }
    .footer-col a { display: block; text-decoration: none; font-size: 0.82rem; color: rgba(247,243,238,0.45); font-weight: 300; margin-bottom: 10px; transition: color 0.3s; }
    .footer-col a:hover { color: var(--cream); }
    .footer-bottom { border-top: 1px solid rgba(247,243,238,0.08); padding-top: 28px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
    .footer-copy { font-size: 0.72rem; color: rgba(247,243,238,0.25); font-weight: 300; }
    .crisis-box { background: rgba(126,181,166,0.12); border-radius: 12px; padding: 14px 22px; border-left: 3px solid var(--sage); }
    .crisis-box strong { color: var(--sage); font-size: 0.78rem; font-weight: 400; }
    .crisis-box p { font-size: 0.75rem; color: rgba(247,243,238,0.55); font-weight: 300; margin-top: 4px; }

    /* MODAL */
    .modal-overlay { position: fixed; inset: 0; background: rgba(44,62,53,0.6); z-index: 1000; display: flex; align-items: center; justify-content: center; padding: 20px; backdrop-filter: blur(4px); animation: fadeUp 0.3s ease; }
    .modal-box { background: var(--white); border-radius: 24px; padding: 48px; max-width: 520px; width: 100%; position: relative; box-shadow: 0 40px 80px rgba(44,62,53,0.2); max-height: 90vh; overflow-y: auto; }
    .modal-close { position: absolute; top: 20px; right: 24px; background: none; border: none; font-size: 1.4rem; cursor: pointer; color: var(--mid); }
    .modal-box h3 { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 300; color: var(--deep); margin-bottom: 12px; }
    .modal-box p { font-size: 0.88rem; line-height: 1.8; color: var(--mid); font-weight: 300; margin-bottom: 16px; }
    .modal-box ul { list-style: none; margin-bottom: 24px; }
    .modal-box ul li { font-size: 0.84rem; color: var(--mid); font-weight: 300; padding: 5px 0 5px 20px; position: relative; line-height: 1.6; }
    .modal-box ul li::before { content: '✦'; position: absolute; left: 0; color: var(--sage); font-size: 0.55rem; top: 9px; }
    .modal-tag { display: inline-block; background: rgba(126,181,166,0.15); color: var(--sage); padding: 4px 14px; border-radius: 20px; font-size: 0.7rem; letter-spacing: 0.1em; margin-bottom: 20px; }

    @keyframes riseIn { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes floatUp { 0%, 100% { transform: translateY(-50%) translateY(0); } 50% { transform: translateY(-50%) translateY(-14px); } }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    @media (max-width: 900px) { .footer-top { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 768px) { .nav-links { display: none; } .floating-card { display: none; } .footer-top { grid-template-columns: 1fr; } .footer-bottom { flex-direction: column; text-align: center; } }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="logo">bloom<span>well</span></div>
  <ul class="nav-links">
    <li><a href="#home">Home</a></li>
    <li><a href="#mindfulness">Pillars</a></li>
    <li><a href="#movement">Breathwork</a></li>
    <li><a href="#nutrition">Practices</a></li>
    <li><a href="#community">Check-In</a></li>
  </ul>
  <button class="nav-cta" onclick="document.getElementById('movement').scrollIntoView({behavior:'smooth'})">Begin</button>
</nav>

<!-- HERO -->
<section id="home">
  <div class="hero-orb orb1"></div>
  <div class="hero-orb orb2"></div>
  <div class="hero-orb orb3"></div>
  <div class="hero-content">
    <p class="eyebrow">A sanctuary for your whole self</p>
    <h1>Nourish your<br/><em>mind, body</em><br/>&amp; spirit.</h1>
    <p class="hero-sub">Evidence-based practices, gentle guidance, and a community that holds space for every version of you — on every kind of day.</p>
    <div class="btn-group">
      <button class="btn-primary" onclick="document.getElementById('nutrition').scrollIntoView({behavior:'smooth'})">Explore Practices</button>
      <button class="btn-ghost" onclick="document.getElementById('mindfulness').scrollIntoView({behavior:'smooth'})">Our Approach</button>
    </div>
  </div>
  <div class="floating-card">
    <div class="icon">🌿</div>
    <p>breathe deeply</p>
  </div>
</section>

<!-- STATS -->
<div class="stats-bar">
  <div class="stat"><div class="stat-num">MBSR</div><div class="stat-label">Mindfulness-Based Stress Reduction — clinically validated</div></div>
